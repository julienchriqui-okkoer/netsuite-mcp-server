{
  "name": "netsuite-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing NetSuite REST API for Spendesk × NetSuite integration flows.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/server-http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/server-http.ts",
    "test:vendors": "npm run build && node scripts/test-netsuite-vendors.mjs",
    "test:http": "node scripts/test-netsuite-http.mjs",
    "test:all": "node scripts/test-all-tools.mjs",
    "test:tools": "npm run build && node scripts/test-all-tools.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.8.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "hono": "^4.12.7",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
